# ═══════════════════════════════════════════════════════════════════════════════
# VARIABLES DE ENTORNO - StyleSwap Marketplace
# ═══════════════════════════════════════════════════════════════════════════════
# Copia este archivo a .env y actualiza los valores según tu entorno

# BACKEND (Node.js + Express)
# ─────────────────────────────────────────────────────────────────────────────

# JWT Secret - CAMBIAR EN PRODUCCIÓN (mínimo 32 caracteres)
JWT_SECRET=tu_clave_secreta_muy_larga_y_segura_aqui

# URL del frontend (para CORS y Socket.IO)
# Desarrollo: http://localhost:5173
# Replit: https://tu-proyecto.replit.dev
# Vercel: https://tu-proyecto.vercel.app
FRONTEND_URL=http://localhost:5173

# Puerto del servidor backend
PORT=3001

# ─── Asistente IA (elige uno — ambos son gratuitos) ──────────────────────────

# OPCIÓN 1: Groq (RECOMENDADO — Gratis, muy rápido)
# Regístrate en: https://console.groq.com
# Modelo usado: llama-3.1-8b-instant
GROQ_API_KEY=

# OPCIÓN 2: Google Gemini (Gratis — gemini-1.5-flash)
# Obtén tu clave en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# FRONTEND (React + Vite)
# ─────────────────────────────────────────────────────────────────────────────

# URL base de la API (debe coincidir con el backend deployado)
# Desarrollo: http://localhost:3001
# Replit: https://tu-proyecto.replit.dev
# Vercel: https://tu-proyecto-backend.replit.dev (o tu backend)
VITE_API_URL=http://localhost:3001
